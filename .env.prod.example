# Domaine public servi par Traefik (sans http://)
DOMAIN=impostor.exemple.fr

# Nom du réseau Docker EXTERNE de ta stack Traefik.
# Trouve-le avec :  docker network ls
TRAEFIK_NETWORK=traefik

# Entrypoint Traefik à utiliser :
#   web        -> HTTP  (port 80)
#   websecure  -> HTTPS (port 443)  -- mets cette valeur si ton TLS est déjà géré
TRAEFIK_ENTRYPOINT=web

# Nom du certresolver Let's Encrypt (utilisé seulement si tu décommentes les
# labels tls.* dans docker-compose.prod.yml). Sinon laisse tel quel.
CERT_RESOLVER=letsencrypt

# Mot de passe administrateur de l'app
ADMIN_PASSWORD=change-moi

# Mot de passe PostgreSQL
POSTGRES_PASSWORD=change-moi-aussi
