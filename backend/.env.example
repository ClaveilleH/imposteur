# Port d'écoute de l'API
PORT=3000

# Connexion PostgreSQL (correspond au docker-compose.yml à la racine)
DATABASE_URL=postgres://impostor:impostor@localhost:5432/impostor

# Origine autorisée pour le CORS (frontend Vite)
CORS_ORIGIN=http://localhost:5173

# Mot de passe admin (en clair, la sécurité n'est pas un enjeu ici)
ADMIN_PASSWORD=admin
